/ {
    input_processors {
        zip_scroll_x_scaler: zip_scroll_x_scaler {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <2>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_HWHEEL>;
            track-remainders;
        };
        zip_scroll_y_scaler: zip_scroll_y_scaler {
            compatible = "zmk,input-processor-scaler";
            #input-processor-cells = <2>;
            type = <INPUT_EV_REL>;
            codes = <INPUT_REL_WHEEL>;
            track-remainders;
        };
    };
};

/ {
    trackball_listener: trackball_listener {
        status = "okay";
        compatible = "zmk,input-listener";
        device = <&trackball>;

        // input-processors = <&mouse_runtime_input_processor>;
        input-processors = <
            &mouse_runtime_input_processor
            //&zip_temp_layer 6 100000 // AMLレイヤー、タイムアウト時間
            &zip_xy_scaler 2 3 // カーソル移動量2/3倍
            &zip_xy_transform INPUT_TRANSFORM_Y_INVERT // カーソルの移動方向調整
        >;
    };
};

&trackball_listener {
    scroller_y {
        layers = <5>; // 縦スクロールレイヤー
        input-processors = <
            // &scroll_runtime_input_processor
            &zip_scroll_transform (INPUT_TRANSFORM_X_INVERT) // スクロール方向調整
            &zip_xy_to_scroll_mapper
            &zip_scroll_x_scaler 0 3 // X軸スクロール量0/3倍
            &zip_scroll_y_scaler 2 3 // Y軸スクロール量2/3倍
        >;
    };
    scroller_x {
        layers = <7>; // 横スクロールレイヤー
        input-processors = <
            &zip_scroll_transform (INPUT_TRANSFORM_X_INVERT) // スクロール方向調整
            &zip_xy_to_scroll_mapper
            &zip_scroll_x_scaler 2 3 // X軸スクロール量2/3倍
            &zip_scroll_y_scaler 0 3 // Y軸スクロール量0/3倍
        >;
    };
};

&pinctrl {
    spi0_default: spi0_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
        };
    };

    spi0_sleep: spi0_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 5)>,
                <NRF_PSEL(SPIM_MOSI, 0, 4)>,
                <NRF_PSEL(SPIM_MISO, 0, 4)>;
            low-power-enable;
        };
    };
};

&spi0 {
    status = "okay";
    compatible = "nordic,nrf-spim";
    pinctrl-0 = <&spi0_default>;
    pinctrl-1 = <&spi0_sleep>;
    pinctrl-names = "default", "sleep";
    cs-gpios = <&gpio0 9 GPIO_ACTIVE_LOW>;

    trackball: trackball@0 {
        status = "okay";
        compatible = "pixart,pmw3610";
        reg = <0>;
        spi-max-frequency = <2000000>;
        irq-gpios = <&gpio0 2 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
        // automouse-layer = <6>;
        // scroll-layers = <5>;
    };
};


